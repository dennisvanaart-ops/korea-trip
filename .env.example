# Flight API provider: mock | amadeus | aviationstack | cirium
# Leave as "mock" to use simulated flight data (no API key needed)
FLIGHT_API_PROVIDER=mock

# Amadeus (https://developers.amadeus.com/)
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

# AviationStack (https://aviationstack.com/)
AVIATIONSTACK_API_KEY=

# Cirium (https://www.cirium.com/)
CIRIUM_APP_ID=
CIRIUM_APP_KEY=
